// Connexion à PostgreSQL
datasource db {
  provider = "postgresql"
}

// Générateur du client Prisma
generator client {
  provider = "prisma-client-js"
}

// Table des utilisateurs (compte de connexion)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  nom       String
  prenom    String
  createdAt DateTime @default(now())

  clients Client[]
  devis   Devis[]
}

// Table des clients
model Client {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  email     String?
  telephone String?
  entreprise String?
  adresse   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User  @relation(fields: [userId], references: [id])

  devis Devis[]
}

// Table des devis
model Devis {
  id          Int      @id @default(autoincrement())
  numero      String   @unique
  statut      String   @default("brouillon") // brouillon, envoyé, accepté, refusé
  dateEmission DateTime @default(now())
  dateEcheance DateTime?
  totalHT     Float    @default(0)
  totalTTC    Float    @default(0)
  tva         Float    @default(20)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId   Int
  user     User   @relation(fields: [userId], references: [id])

  clientId Int
  client   Client @relation(fields: [clientId], references: [id])

  lignes LigneDevis[]
}

// Table des lignes de devis (les produits/services dans un devis)
model LigneDevis {
  id          Int    @id @default(autoincrement())
  description String
  quantite    Float
  prixUnitaire Float
  total       Float

  devisId Int
  devis   Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)
}
